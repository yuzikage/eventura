# Copy this file to .env and fill in your values

FLASK_ENV=development

# Generate a strong random string for both of these
# python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Main Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Separate Neon database used only by pytest (keeps test data off the main DB)
TEST_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname_test?sslmode=require

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
